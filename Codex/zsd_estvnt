IDIOMA = SY-LANGU.

*SELECT
*   SUBSTRING( M~MATNR,11,8 )  AS Material
*   ,M~BISMT AS CodigoLegado
*FROM MARA AS M
*INTO TABLE @data(MatLeg).

SELECT
  ORG~VTEXT AS NombreOrganizacion
  ,OFVNT~VKBUR AS OficinaVentas
  ,OFVNT~BEZEI AS NombreOfVentas
  ,ENC~FKDAT AS FechaDocumento
  ,ENC~ZZROUTE AS Ruta
  ,DET~MATNR AS Material
*  ,PMAT~BISMT AS MaterialLegado
  ,CASE WHEN MATP~MATNR IS NULL THEN MAT~BISMT ELSE MATP~BISMT END AS MaterialLegado
*  ,ML~CODIGOLEGADO AS MaterialLegado
  ,NMAT~MAKTX AS NombreProducto
  ,DET~VRKME AS UnidadMedida
  ,SUM( CASE WHEN ENC~VF_STATUS = 'C' OR NOT ECF~FKART IS NULL THEN 0 ELSE (
      CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X' THEN - DET~FKIMG  ELSE DET~FKIMG END
      ) END ) AS CantidadFacturada
  ,SUM( CASE WHEN ENC~VF_STATUS = 'C' OR NOT ECF~FKART IS NULL THEN 0 ELSE (
      CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X' THEN - DET~FKLMG  ELSE DET~FKLMG END
      ) END ) AS CantidadFacturadaUME
  ,SUM( ROUND( ENC~KURRF * (
      CASE WHEN ENC~VF_STATUS = 'C' THEN 0 ELSE (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) THEN - DET~NETWR  ELSE DET~NETWR END
      ) END ), 2 )
   ) AS ValorNeto
 ,SUM( ROUND( ENC~KURRF * (
      CASE WHEN ENC~VF_STATUS = 'C' THEN 0 ELSE (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) THEN - ( DET~NETWR + DET~MWSBP )  ELSE ( DET~NETWR + DET~MWSBP ) END
      ) END ), 2 )
   ) AS ValorTotal
  ,CASE WHEN SUBSTRING( MAT~MATKL,1,3 ) = 'SER' THEN 'SERVICIO'
      WHEN SUBSTRING( MAT~MATKL,1,3 ) = 'RNV' THEN 'ENVASE'
      ELSE 'PRODUCTO' END AS TipoProducto
  ,CASE WHEN MAT~BISMT = '133' THEN '33' ELSE (
      CASE WHEN MAT~PRDHA = ' ' THEN  '00' ELSE LINEA~PRODH END )
   END AS CodigoLinea
  ,CASE
      WHEN MAT~BISMT = '133' THEN 'GAS CARBONICO'
      WHEN MAT~PRDHA = ' ' THEN 'NO APLICA'
      ELSE LINEA~VTEXT
    END AS LineaProducto
  ,FAM~PRODH AS CodigoFamilia
  ,FAM~VTEXT AS FamiliaProducto
  ,MARCA~PRODH AS CodigoMarca
  ,MARCA~VTEXT AS MarcaProducto
  ,ENC~LAND1 AS PaisDestino
* SUMATORIA Y MULTIPLICACION POR TIPO DE CAMBIO
  ,SUM( ROUND( (
* SI EL DOCUMENTO ESTA ANULADO SE COLOCA VALOR 0
    CASE WHEN ENC~VF_STATUS = 'C' OR NOT ECF~FKART IS NULL THEN 0 ELSE
* CANTIDAD UME MULTIPLICADA POR EL VALOR DE REDUCIDO
    DET~FKLMG * CAST( CASE

*   CANTIDADES REDUCIDAS PARA CERVEZA REFRESCO LICORES
    WHEN NOT REDU~UMREN IS NULL AND (
      SUBSTRING( MAT~PRDHA,1,2 ) = '01' OR
      SUBSTRING( MAT~PRDHA,1,2 ) = '02' OR
      SUBSTRING( MAT~PRDHA,1,2 ) = '06'
      ) THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU~UMREN , REDU~UMREZ, 6 ) )
          ELSE  DIVISION( REDU~UMREN , REDU~UMREZ, 6 )
        END )
*   CANTIDADES REDUCIDAS DE LITROS A CAJAS
    WHEN REDU~UMREN IS NULL AND (
      SUBSTRING( MAT~PRDHA,1,2 ) = '01' OR
      SUBSTRING( MAT~PRDHA,1,2 ) = '02' OR
      SUBSTRING( MAT~PRDHA,1,2 ) = '06'
      ) THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( DIVISION( REDU_L~UMREN,REDU_L~UMREZ,6 ),DIVISION( 84,10,2 ),6 ) )
          ELSE DIVISION( DIVISION( REDU_L~UMREN,REDU_L~UMREZ,6 ),DIVISION( 84,10,2 ),6 )
        END )
**   CANTIDADES REDUCIDAS DE BNC CONCENTRADOS
    WHEN SUBSTRING( MAT~PRDHA,1,2 ) = '03' AND SUBSTRING( MAT~PRDHA,3,3 ) = '141'
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU_L~UMREN , REDU_L~UMREZ ,6 ) )
          ELSE DIVISION( REDU_L~UMREN , REDU_L~UMREZ ,6 )
          END )
**   CANTIDADES REDUCIDAS DE BNC LIBRAS
    WHEN SUBSTRING( MAT~PRDHA,1,2 ) = '03' AND NOT REDU_LB~UMREN IS NULL
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU_LB~UMREN , REDU_LB~UMREZ ,6 ) )
          ELSE DIVISION( REDU_LB~UMREN , REDU_LB~UMREZ ,6 )
          END )
**   CANTIDADES REDUCIDAS DE BNC LITROS
    WHEN SUBSTRING( MAT~PRDHA,1,2 ) = '03' AND NOT REDU_L~UMREN IS NULL
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU_L~UMREN , REDU_L~UMREZ ,6 ) )
          ELSE DIVISION( REDU_L~UMREN , REDU_L~UMREZ ,6 )
          END )
**   CANTIDADES REDUCIDAS DE BNC KILOS
    WHEN SUBSTRING( MAT~PRDHA,1,2 ) = '03' AND NOT REDU_KG~UMREN IS NULL
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( DIVISION( REDU_KG~UMREN,REDU_KG~UMREZ,6 ),DIVISION( 454,1000,3 ),6 ) )
          ELSE DIVISION( DIVISION( REDU_KG~UMREN,REDU_KG~UMREZ,6 ),DIVISION( 454,1000,3 ),6 )
        END )
*   CANTIDAD REDUCIDAS PARA BNC LITROS
    WHEN SUBSTRING( MAT~PRDHA,1,2 ) = '03' AND NOT (
      SUBSTRING( MAT~PRDHA,3,3 ) = '138' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = 'A09' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = 'A08' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = '140'
      ) THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU_L~UMREN , REDU_L~UMREZ, 6 ) )
          ELSE DIVISION( REDU_L~UMREN , REDU_L~UMREZ, 6 )
        END )
*   CANTIDADES REDUCIDAS PARA AP GARRAFONES
    WHEN SUBSTRING( MAT~PRDHA,1,2 ) = '04'
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU_G~UMREN , REDU_G~UMREZ, 6 ) )
          ELSE DIVISION( REDU_G~UMREN , REDU_G~UMREZ, 6 )
        END )
*   CANTIDADES REDUCIDADS A LITROS
    WHEN SUBSTRING( MAT~PRDHA,1,2 ) = '07' AND MAT~VOLUM > 0 AND NOT REDU_L~UMREN IS NULL
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU_L~UMREN , REDU_L~UMREZ, 6 ) )
          ELSE DIVISION( REDU_L~UMREN , REDU_L~UMREZ, 6 )
          END )
*   CANTIDADES REDUCIDAS ALIMENTOS LIBRAS
    WHEN NOT REDU_LB~UMREN IS NULL AND ( (
      SUBSTRING( MAT~PRDHA,1,2 ) = '07' OR
      SUBSTRING( MAT~PRDHA,1,2 ) = '05' )
      OR (
      SUBSTRING( MAT~PRDHA,3,3 ) = '138' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = 'A09' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = 'A08' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = '140' ) )
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( REDU_LB~UMREN , REDU_LB~UMREZ, 6 ) )
          ELSE DIVISION( REDU_LB~UMREN , REDU_LB~UMREZ, 6 )
          END )
*   CANTIDADES REDUCIDAS ALIMENTOS KILOS
    WHEN NOT REDU_KG~UMREN IS NULL AND ( (
      SUBSTRING( MAT~PRDHA,1,2 ) = '07' OR
      SUBSTRING( MAT~PRDHA,1,2 ) = '05' )
      OR (
      SUBSTRING( MAT~PRDHA,3,3 ) = '138' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = 'A09' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = 'A08' OR
      SUBSTRING( MAT~PRDHA,3,3 ) = '140' ) )
      THEN (
        CASE WHEN ( ENC~VBTYP = 'O' OR ENC~VBTYP = '6' ) OR DET~SHKZG = 'X'
          THEN - ( DIVISION( DIVISION( REDU_KG~UMREN,REDU_KG~UMREZ,6 ),DIVISION( 454,1000,3 ),6 ) )
          ELSE DIVISION( DIVISION( REDU_KG~UMREN,REDU_KG~UMREZ,6 ),DIVISION( 454,1000,3 ),6 )
        END )
    ELSE 0 END AS DEC )

* CANTIDAD UME MULTIPLICADA POR EL VALOR DE REDUCIDO - CIERRE
     END
* SI EL DOCUMENTO ESTA ANULADO SE COLOCA VALOR 0 - CIERRE
     ), 8 )
* MULTIPLICACION POR TIPO DE CAMBIO - CIERRE
     ) AS CantidadReducida
FROM VBRK AS ENC
  INNER JOIN TVKOT AS ORG ON ENC~VKORG = ORG~VKORG AND ORG~SPRAS = @IDIOMA
  INNER JOIN VBRP AS DET ON ENC~VBELN = DET~VBELN
  INNER JOIN MARA AS MAT ON DET~MATNR = MAT~MATNR
  INNER JOIN MAKT AS NMAT ON DET~MATNR = NMAT~MATNR AND NMAT~SPRAS = @IDIOMA
  INNER JOIN TVKBT AS OFVNT ON DET~VKBUR = OFVNT~VKBUR AND OFVNT~SPRAS = @IDIOMA
  LEFT JOIN T179T AS LINEA ON SUBSTRING( MAT~PRDHA,1,2 ) = LINEA~PRODH AND LINEA~SPRAS = @IDIOMA
  LEFT JOIN T179T AS FAM ON SUBSTRING( MAT~PRDHA,1,5 ) = FAM~PRODH AND FAM~SPRAS = @IDIOMA
  LEFT JOIN T179T AS MARCA ON SUBSTRING( MAT~PRDHA,1,9 ) = MARCA~PRODH AND MARCA~SPRAS = @IDIOMA
  LEFT JOIN MARM AS REDU ON MAT~MATNR = REDU~MATNR AND REDU~MEINH = 'CJR'
  LEFT JOIN MARM AS REDU_L ON MAT~MATNR = REDU_L~MATNR AND REDU_L~MEINH = 'L'
  LEFT JOIN MARM AS REDU_G ON MAT~MATNR = REDU_G~MATNR AND REDU_G~MEINH = 'GRR'
  LEFT JOIN MARM AS REDU_LB ON MAT~MATNR = REDU_LB~MATNR AND REDU_LB~MEINH = 'LB'
  LEFT JOIN MARM AS REDU_KG ON MAT~MATNR = REDU_KG~MATNR AND REDU_KG~MEINH = 'KG'
  LEFT JOIN ZSDT_CANT_FACT AS ECF ON ENC~BUKRS = ECF~BUKRS AND ENC~VKORG = ECF~VKORG AND ENC~FKART = ECF~FKART
*  LEFT JOIN @MatLeg AS ML ON MAT~BISMT = ML~MATERIAL
  LEFT JOIN MARA AS MATP ON SUBSTRING( MATP~MATNR,11,8 ) = MAT~BISMT
WHERE ENC~VKORG IN @ORGVENT
  AND ENC~VTWEG IN @CANDIST
  AND ENC~SPART IN @SECTOR
  AND ENC~FKDAT IN @FECHDOC
  AND DET~VKBUR IN @OFVNT
  AND ENC~VBTYP NOT IN ('N','S')
  AND ENC~FKART NOT IN ('ZERO','ZASR','ZCSR','ZIVS')
  AND DET~FKIMG > 0
GROUP BY ORG~VTEXT
  ,ENC~FKDAT
  ,ENC~ZZROUTE
  ,DET~MATNR
  ,MAT~BISMT
  ,MATP~BISMT
  ,MATP~MATNR
  ,NMAT~MAKTX
  ,DET~VRKME
  ,DET~KURSK
  ,ENC~LAND1
  ,REDU~MEINH
  ,MAT~PRDHA
  ,OFVNT~VKBUR
  ,OFVNT~BEZEI
  ,LINEA~PRODH
  ,LINEA~VTEXT
  ,FAM~PRODH
  ,FAM~VTEXT
  ,MARCA~PRODH
  ,MARCA~VTEXT
  ,MAT~MATKL
*  ,REDU~UMREN
*  ,REDU~UMREZ
*  ,REDU_L~UMREN
*  ,REDU_L~UMREZ
*  ,REDU_G~UMREN
*  ,REDU_G~UMREZ
*  ,MAT~VOLUM
*  ,REDU_LB~UMREN
*  ,REDU_LB~UMREZ
*  ,REDU_KG~UMREN
*  ,REDU_KG~UMREZ
INTO TABLE @it_data.

DELETE ADJACENT DUPLICATES FROM IT_DATA COMPARING ALL FIELDS.

